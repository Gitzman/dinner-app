<div class="max-w-2xl mx-auto">
  <h1 class="text-3xl font-bold text-gray-800 mb-2">Your Profile</h1>
  <p class="text-gray-500 mb-8">Tell us about your family so we can suggest the perfect meals.</p>

  <%= form_with model: @profile, url: profile_path, method: :patch, class: "space-y-6" do |f| %>
    <div>
      <%= f.label :name, "Your name", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name, placeholder: "e.g. Sarah", class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-orange-400" %>
    </div>

    <div>
      <%= f.label :family_description, "Tell us about your family", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_area :family_description, rows: 3,
          placeholder: "e.g. husband, 6-year-old Liam, 3-year-old Maya — Liam is picky, Maya has a peanut allergy",
          class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-orange-400" %>
    </div>

    <div>
      <p class="block text-sm font-medium text-gray-700 mb-2">Cookware you own</p>
      <% cookware_options = ["Air fryer", "Wok", "Instant Pot", "Cast iron", "Dutch oven", "Sheet pan", "Slow cooker", "Grill pan", "Steamer", "Stand mixer", "Food processor", "Basic pots & pans"] %>
      <% selected_cookware = @profile.cookware.to_s.split(",").map(&:strip) %>
      <div class="grid grid-cols-2 gap-2">
        <% cookware_options.each do |item| %>
          <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
            <input type="checkbox" name="profile[cookware_items][]" value="<%= item %>"
              <%= "checked" if selected_cookware.include?(item) %>
              class="rounded border-gray-300 text-orange-500 focus:ring-orange-400">
            <%= item %>
          </label>
        <% end %>
      </div>
    </div>

    <div>
      <p class="block text-sm font-medium text-gray-700 mb-2">Cuisine preferences</p>
      <% cuisine_options = ["Italian", "Mexican", "Asian", "Mediterranean", "American", "Indian", "Middle Eastern", "French", "Japanese", "Thai"] %>
      <% selected_cuisines = @profile.cuisine_preferences.to_s.split(",").map(&:strip) %>
      <div class="flex flex-wrap gap-2">
        <% cuisine_options.each do |cuisine| %>
          <label class="cursor-pointer">
            <input type="checkbox" name="profile[cuisine_items][]" value="<%= cuisine %>"
              <%= "checked" if selected_cuisines.include?(cuisine) %>
              class="sr-only peer">
            <span class="px-3 py-1 rounded-full border border-gray-300 text-sm peer-checked:bg-orange-500 peer-checked:text-white peer-checked:border-orange-500 hover:border-orange-400 transition">
              <%= cuisine %>
            </span>
          </label>
        <% end %>
      </div>
    </div>

    <div>
      <p class="block text-sm font-medium text-gray-700 mb-2">Recipe style</p>
      <div class="flex gap-6">
        <label class="flex items-center gap-2 cursor-pointer">
          <%= f.radio_button :cooking_style, "detailed", class: "text-orange-500 focus:ring-orange-400" %>
          <span class="text-sm text-gray-700">Detailed recipes with measurements</span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
          <%= f.radio_button :cooking_style, "rough", class: "text-orange-500 focus:ring-orange-400" %>
          <span class="text-sm text-gray-700">Rough steps only</span>
        </label>
      </div>
    </div>

    <div>
      <%= f.label :culinary_goals, "Any culinary goals?", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_area :culinary_goals, rows: 2,
          placeholder: "e.g. eat less meat, try new cuisines, keep it under 30 minutes",
          class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-orange-400" %>
    </div>

    <%= f.submit "Save Profile", class: "w-full bg-orange-500 text-white py-3 rounded-lg font-semibold hover:bg-orange-600 transition cursor-pointer" %>
  <% end %>
</div>
