<div class="mb-6">
  <h1 class="text-3xl font-bold text-gray-800">My Favorites</h1>
  <p class="text-sm text-gray-500 mt-1">Recipes you've saved for later</p>
</div>

<% if @favorites.any? %>
  <div class="space-y-6">
    <% @favorites.each do |meal| %>
      <% suggestions = JSON.parse(meal.suggestions, symbolize_names: true) %>
      <% suggestions.each_with_index do |recipe, i| %>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-orange-100">
          <div class="flex items-start justify-between mb-3">
            <div>
              <span class="text-xs font-semibold text-orange-500 uppercase tracking-wide">
                <%= meal.flow_type&.titleize %>
              </span>
              <h2 class="text-xl font-bold text-gray-800 mt-0.5"><%= recipe[:name] %></h2>
              <p class="text-gray-600 text-sm mt-1"><%= recipe[:description] %></p>
            </div>
            <div class="flex items-center gap-3 ml-4">
              <span class="text-sm text-gray-400 whitespace-nowrap">⏱ <%= recipe[:estimated_time] %></span>
              <%= button_to favorite_path(meal.favorites.find_by(user: current_user)),
                    method: :delete,
                    class: "text-red-500 hover:text-red-700 transition text-2xl",
                    title: "Remove from favorites" do %>
                ♥
              <% end %>
            </div>
          </div>

          <% if recipe[:cookware_used]&.any? %>
            <div class="flex flex-wrap gap-1.5 mb-4">
              <% recipe[:cookware_used].each do |item| %>
                <span class="bg-orange-50 text-orange-700 text-xs px-2 py-0.5 rounded-full border border-orange-200"><%= item %></span>
              <% end %>
            </div>
          <% end %>

          <div class="grid md:grid-cols-2 gap-4">
            <div>
              <h3 class="text-sm font-semibold text-gray-700 mb-2">Ingredients</h3>
              <ul class="space-y-1">
                <% recipe[:ingredients].each do |ingredient| %>
                  <li class="text-sm text-gray-600 flex gap-2"><span class="text-orange-400">•</span><%= ingredient %></li>
                <% end %>
              </ul>
            </div>

            <div>
              <h3 class="text-sm font-semibold text-gray-700 mb-2">Instructions</h3>
              <p class="text-sm text-gray-600 leading-relaxed"><%= recipe[:instructions] %></p>
            </div>
          </div>

          <% if recipe[:kid_contribution].present? %>
            <div class="mt-4 bg-yellow-50 border border-yellow-200 rounded-xl px-4 py-3">
              <p class="text-sm text-yellow-800"><span class="font-semibold">👧 Kids can help:</span> <%= recipe[:kid_contribution] %></p>
            </div>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="bg-white rounded-2xl p-12 shadow-sm border border-orange-100 text-center">
    <p class="text-4xl mb-4">♡</p>
    <h2 class="text-xl font-bold text-gray-800 mb-2">No favorites yet</h2>
    <p class="text-gray-500 mb-6">When you find a recipe you love, tap the heart to save it here.</p>
    <%= link_to "Get Dinner Ideas", meals_path, class: "bg-orange-500 text-white px-6 py-2.5 rounded-full text-sm font-semibold hover:bg-orange-600 transition" %>
  </div>
<% end %>
