<% labels = {
  "pantry"     => { title: "Use What You Have", prompt: "What ingredients do you have?", placeholder: "e.g. chicken thighs, broccoli, soy sauce, garlic, rice" },
  "ingredient" => { title: "Hero Ingredient",   prompt: "What ingredient do you want to cook with?", placeholder: "e.g. salmon, chickpeas, butternut squash" },
  "cuisine"    => { title: "I'm in the Mood For...", prompt: "What are you in the mood for?", placeholder: "e.g. something cozy, Thai food, quick pasta" }
} %>
<% config = labels[@flow_type] || labels["pantry"] %>

<div class="max-w-xl mx-auto" data-controller="loading">
  <%= link_to "← Back", meals_path, class: "text-sm text-orange-600 hover:underline mb-6 inline-block" %>

  <h1 class="text-3xl font-bold text-gray-800 mb-2"><%= config[:title] %></h1>

  <%= form_with url: meals_path, method: :post, data: { loading_target: "form", action: "submit->loading#submit" } do |f| %>
    <%= f.hidden_field :flow_type, value: @flow_type %>

    <div class="mt-6">
      <%= label_tag :user_input, config[:prompt], class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= text_area_tag :user_input, nil, rows: 3, placeholder: config[:placeholder],
          class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-orange-400",
          autofocus: true %>
    </div>

    <button type="submit" class="mt-4 w-full bg-orange-500 text-white py-3 rounded-lg font-semibold hover:bg-orange-600 transition">
      Get Meal Ideas ✨
    </button>
  <% end %>

  <!-- Loading overlay -->
  <div data-loading-target="overlay" class="hidden fixed inset-0 bg-orange-50/90 z-50 flex flex-col items-center justify-center">
    <div class="flex flex-col items-center gap-6">
      <div class="w-16 h-16 border-4 border-orange-200 border-t-orange-500 rounded-full animate-spin"></div>
      <p data-loading-target="message" class="text-xl font-semibold text-gray-700 transition-opacity duration-300"></p>
    </div>
  </div>
</div>
