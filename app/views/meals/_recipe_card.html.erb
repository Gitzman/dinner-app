<div class="bg-white rounded-2xl p-6 shadow-sm border border-orange-100">
  <div class="flex items-start justify-between mb-3">
    <div>
      <span class="text-xs font-semibold text-orange-500 uppercase tracking-wide">Option <%= index + 1 %></span>
      <h2 class="text-xl font-bold text-gray-800 mt-0.5"><%= meal[:name] %></h2>
      <p class="text-gray-600 text-sm mt-1"><%= meal[:description] %></p>
    </div>
    <div class="flex items-center gap-3 ml-4">
      <% if signed_in %>
        <button data-controller="favorite"
                data-favorite-meal-id-value="<%= meal_id %>"
                data-favorite-suggestion-index-value="<%= index %>"
                data-favorite-favorited-value="<%= favorited %>"
                data-action="click->favorite#toggle"
                class="text-red-400 hover:text-red-500 transition cursor-pointer"
                aria-label="Favorite this meal">
          <svg data-heart="filled" class="w-6 h-6 hidden" fill="currentColor" viewBox="0 0 24 24">
            <path d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
          </svg>
          <svg data-heart="outline" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
          </svg>
        </button>
        <% recipe_slug = meal[:name].to_s.downcase.gsub(/[^a-z0-9]+/, "-").gsub(/\A-|-\z/, "") %>
        <% share_url = shared_meal_url(meal_id, slug: recipe_slug) %>
        <button data-controller="share"
                data-share-url-value="<%= share_url %>"
                data-share-title-value="<%= meal[:name] %>"
                data-share-text-value="<%= meal[:description] %>"
                data-action="click->share#share"
                class="text-gray-400 hover:text-orange-500 transition cursor-pointer"
                aria-label="Share this recipe">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7.217 10.907a2.25 2.25 0 1 0 0 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186 9.566-5.314m-9.566 7.5 9.566 5.314m0 0a2.25 2.25 0 1 0 3.935 2.186 2.25 2.25 0 0 0-3.935-2.186Zm0-12.814a2.25 2.25 0 1 0 3.935-2.186 2.25 2.25 0 0 0-3.935 2.186Z" />
          </svg>
        </button>
      <% else %>
        <%= link_to new_user_registration_path, class: "text-red-400 hover:text-red-500 transition", title: "Sign up to save this recipe" do %>
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
          </svg>
        <% end %>
      <% end %>
      <span class="text-sm text-gray-400 whitespace-nowrap">⏱ <%= meal[:estimated_time] %></span>
    </div>
  </div>

  <% if meal[:cookware_used]&.any? %>
    <div class="flex flex-wrap gap-1.5 mb-4">
      <% meal[:cookware_used].each do |item| %>
        <span class="bg-orange-50 text-orange-700 text-xs px-2 py-0.5 rounded-full border border-orange-200"><%= item %></span>
      <% end %>
    </div>
  <% end %>

  <% recipe_stats = local_assigns[:stats] %>
  <% if recipe_stats && recipe_stats[:made_count] > 0 %>
    <div class="flex flex-wrap items-center gap-3 mb-4 text-xs text-gray-500">
      <span>Made <%= recipe_stats[:made_count] %> <%= recipe_stats[:made_count] == 1 ? "time" : "times" %></span>
      <% if recipe_stats[:avg_recipe_rating] %>
        <span class="text-amber-500">★ <%= format("%.1f", recipe_stats[:avg_recipe_rating]) %>/5</span>
      <% end %>
      <% if recipe_stats[:avg_kid_tip_rating] && recipe_stats[:avg_kid_tip_rating] > 3.5 %>
        <span class="bg-amber-50 text-amber-700 px-2 py-0.5 rounded-full border border-amber-200" title="Families found the kid tip helpful">👨‍🍳 Mini-Sous-Chef Approved</span>
      <% end %>
    </div>
  <% end %>

  <div class="grid md:grid-cols-2 gap-4">
    <div>
      <h3 class="text-sm font-semibold text-gray-700 mb-2">Ingredients</h3>
      <ul class="space-y-1">
        <% meal[:ingredients].each do |ingredient| %>
          <li class="text-sm text-gray-600 flex gap-2"><span class="text-orange-400">•</span><%= ingredient %></li>
        <% end %>
      </ul>
    </div>

    <div>
      <h3 class="text-sm font-semibold text-gray-700 mb-2">Instructions</h3>
      <ol class="space-y-1 list-decimal list-inside">
        <% Array(meal[:instructions]).each do |step| %>
          <li class="text-sm text-gray-600"><%= step %></li>
        <% end %>
      </ol>
    </div>
  </div>

  <% if meal[:kid_contribution].present? %>
    <div class="mt-4 bg-yellow-50 border border-yellow-200 rounded-xl px-4 py-3">
      <p class="text-sm text-yellow-800"><span class="font-semibold">👧 Kids can help:</span> <%= meal[:kid_contribution] %></p>
    </div>
  <% end %>

  <% if signed_in %>
    <% user_interaction = local_assigns[:user_interaction] %>
    <% is_editing = user_interaction.present? %>
    <div class="mt-4"
         data-controller="rating"
         data-rating-meal-id-value="<%= meal_id %>"
         data-rating-suggestion-index-value="<%= index %>"
         data-rating-has-kid-contribution-value="<%= meal[:kid_contribution].present? %>"
         data-rating-existing-recipe-rating-value="<%= is_editing ? user_interaction.recipe_rating : 0 %>"
         data-rating-existing-kid-tip-rating-value="<%= is_editing ? (user_interaction.kid_tip_rating || 0) : 0 %>"
         data-rating-editing-value="<%= is_editing %>">
      <button data-action="click->rating#open"
              class="w-full py-2.5 rounded-xl text-sm font-semibold transition cursor-pointer
                     <%= is_editing ? 'border-2 border-green-500 text-green-600 hover:bg-green-50' : 'border-2 border-orange-400 text-orange-500 hover:bg-orange-50' %>">
        <span data-rating-target="buttonText"><%= is_editing ? "✓ Edit My Review" : "I Made This" %></span>
      </button>

      <%# Rating Modal %>
      <div data-rating-target="modal" class="fixed inset-0 z-50 flex items-center justify-center hidden">
        <div data-rating-target="backdrop"
             data-action="click->rating#closeBackdrop"
             class="absolute inset-0 bg-black/40 backdrop-blur-sm transition-opacity duration-200 opacity-0"></div>
        <div data-panel class="relative bg-white rounded-2xl shadow-xl p-6 w-full max-w-sm mx-4 transition-all duration-200 opacity-0 scale-95">
          <button data-action="click->rating#close" class="absolute top-3 right-3 text-gray-400 hover:text-gray-600 cursor-pointer">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>

          <h3 class="text-lg font-bold text-gray-800 mb-1"><%= meal[:name] %></h3>

          <div class="mt-4">
            <p class="text-sm font-medium text-gray-700 mb-2">How was the meal?</p>
            <div data-rating-target="recipeStars" class="flex gap-1"></div>
          </div>

          <div data-rating-target="kidSection" class="mt-4 hidden">
            <p class="text-sm font-medium text-gray-700 mb-2">Did the kids help? How was the tip?</p>
            <div data-rating-target="kidStars" class="flex gap-1"></div>
          </div>

          <p data-rating-target="hint" class="mt-4 text-xs text-orange-400 text-center hidden">Tap the stars to rate</p>
          <button data-rating-target="saveButton"
                  data-action="click->rating#save"
                  class="mt-6 w-full bg-orange-500 text-white py-2.5 rounded-xl text-sm font-semibold transition
                         <%= is_editing ? 'hover:bg-orange-600 cursor-pointer' : 'opacity-50 cursor-not-allowed' %>"
                  <%= 'disabled' unless is_editing %>>
            Save
          </button>
        </div>
      </div>
    </div>
  <% end %>
</div>
