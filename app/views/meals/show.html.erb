<div class="mb-6 flex items-center justify-between">
  <div>
    <h1 class="text-3xl font-bold text-gray-800">Tonight's Ideas</h1>
    <p class="text-sm text-gray-500 mt-1">
      <% if @meal.user_input.present? %>
        Based on: <em><%= @meal.user_input %></em>
      <% else %>
        Surprise picks just for you
      <% end %>
    </p>
  </div>
  <%= link_to "Try Another", meals_path, class: "bg-orange-500 text-white px-5 py-2 rounded-full text-sm font-semibold hover:bg-orange-600 transition" %>
</div>

<div class="space-y-6">
  <% @suggestions.each_with_index do |meal, i| %>
    <div class="bg-white rounded-2xl p-6 shadow-sm border border-orange-100">
      <div class="flex items-start justify-between mb-3">
        <div>
          <span class="text-xs font-semibold text-orange-500 uppercase tracking-wide">Option <%= i + 1 %></span>
          <h2 class="text-xl font-bold text-gray-800 mt-0.5"><%= meal[:name] %></h2>
          <p class="text-gray-600 text-sm mt-1"><%= meal[:description] %></p>
        </div>
        <span class="text-sm text-gray-400 whitespace-nowrap ml-4">⏱ <%= meal[:estimated_time] %></span>
      </div>

      <% if meal[:cookware_used]&.any? %>
        <div class="flex flex-wrap gap-1.5 mb-4">
          <% meal[:cookware_used].each do |item| %>
            <span class="bg-orange-50 text-orange-700 text-xs px-2 py-0.5 rounded-full border border-orange-200"><%= item %></span>
          <% end %>
        </div>
      <% end %>

      <div class="grid md:grid-cols-2 gap-4">
        <div>
          <h3 class="text-sm font-semibold text-gray-700 mb-2">Ingredients</h3>
          <ul class="space-y-1">
            <% meal[:ingredients].each do |ingredient| %>
              <li class="text-sm text-gray-600 flex gap-2"><span class="text-orange-400">•</span><%= ingredient %></li>
            <% end %>
          </ul>
        </div>

        <div>
          <h3 class="text-sm font-semibold text-gray-700 mb-2">Instructions</h3>
          <p class="text-sm text-gray-600 leading-relaxed"><%= meal[:instructions] %></p>
        </div>
      </div>

      <% if meal[:kid_contribution].present? %>
        <div class="mt-4 bg-yellow-50 border border-yellow-200 rounded-xl px-4 py-3">
          <p class="text-sm text-yellow-800"><span class="font-semibold">👧 Kids can help:</span> <%= meal[:kid_contribution] %></p>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
