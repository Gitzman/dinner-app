<% content_for :head do %>
  <% first = @suggestions.first %>
  <meta property="og:title" content="<%= first&.dig(:name) || "Dinner Ideas" %>">
  <meta property="og:description" content="<%= first&.dig(:description) || "Check out these dinner suggestions!" %>">
  <meta property="og:image" content="<%= "#{request.base_url}/icon.png" %>">
  <meta property="og:url" content="<%= shared_meal_url(@meal, si: 0) %>">
  <meta property="og:type" content="article">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= first&.dig(:name) || "Dinner Ideas" %>">
  <meta name="twitter:description" content="<%= first&.dig(:description) || "Check out these dinner suggestions!" %>">
  <meta name="twitter:image" content="<%= "#{request.base_url}/icon.png" %>">
<% end %>

<div class="mb-6 flex items-center justify-between">
  <div>
    <h1 class="text-3xl font-bold text-gray-800">Tonight's Ideas</h1>
    <p class="text-sm text-gray-500 mt-1">
      <% if @meal.user_input.present? %>
        Based on: <em><%= @meal.user_input %></em>
      <% else %>
        Surprise picks just for you
      <% end %>
    </p>
  </div>
  <%= link_to "Try Another", meals_path, class: "bg-orange-500 text-white px-5 py-2 rounded-full text-sm font-semibold hover:bg-orange-600 transition" %>
</div>

<div class="space-y-6">
  <% @suggestions.each_with_index do |meal, i| %>
    <%= render "meals/recipe_card", meal: meal, index: i, meal_id: @meal.id, favorited: @favorited_indices.include?(i), signed_in: true %>
  <% end %>
</div>
