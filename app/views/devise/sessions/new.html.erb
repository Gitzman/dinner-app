<% content_for(:skip_nav, true) %>

<div class="min-h-screen bg-orange-50 -mx-4 -mt-8 px-4 flex flex-col">
  <div class="max-w-5xl mx-auto w-full flex items-center justify-between py-5">
    <%= link_to root_path, class: "text-xl font-bold text-orange-600" do %>🍽️ What's for Dinner?<% end %>
    <%= link_to "Sign up", new_user_registration_path, class: "text-sm text-gray-600 hover:text-orange-600 font-medium" %>
  </div>

  <div class="flex-1 flex items-center justify-center pb-16">
    <div class="w-full max-w-md">
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
        <h1 class="text-2xl font-bold text-gray-800 mb-1 text-center">Welcome back</h1>
        <p class="text-sm text-gray-500 text-center mb-6">Sign in to plan tonight's dinner</p>

        <% if alert.present? %>
          <div class="bg-red-50 border border-red-200 rounded-lg px-4 py-3 mb-4">
            <p class="text-sm text-red-800"><%= alert %></p>
          </div>
        <% end %>
        <% if notice.present? %>
          <div class="bg-green-50 border border-green-200 rounded-lg px-4 py-3 mb-4">
            <p class="text-sm text-green-800"><%= notice %></p>
          </div>
        <% end %>

        <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-4" }) do |f| %>
          <div>
            <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email",
                class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-orange-400" %>
          </div>

          <div>
            <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.password_field :password, autocomplete: "current-password",
                class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-orange-400" %>
          </div>

          <% if devise_mapping.rememberable? %>
            <div class="flex items-center gap-2">
              <%= f.check_box :remember_me, class: "rounded border-gray-300 text-orange-500 focus:ring-orange-400" %>
              <%= f.label :remember_me, class: "text-sm text-gray-600" %>
            </div>
          <% end %>

          <%= f.submit "Sign in", class: "w-full bg-orange-500 text-white py-3 rounded-lg font-semibold hover:bg-orange-600 transition cursor-pointer" %>
        <% end %>
      </div>

      <div class="mt-6 text-center">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>
