<% content_for :head do %>
  <% featured = @suggestions.first %>
  <meta property="og:title" content="<%= featured&.dig(:name) || "Dinner Ideas" %>">
  <meta property="og:description" content="<%= featured&.dig(:description) || "Check out these dinner suggestions!" %>">
  <meta property="og:image" content="<%= "#{request.base_url}/icon.png" %>">
  <meta property="og:url" content="<%= shared_meal_url(@meal, si: @suggestion_offset) %>">
  <meta property="og:type" content="article">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= featured&.dig(:name) || "Dinner Ideas" %>">
  <meta name="twitter:description" content="<%= featured&.dig(:description) || "Check out these dinner suggestions!" %>">
  <meta name="twitter:image" content="<%= "#{request.base_url}/icon.png" %>">
<% end %>

<div class="mb-6">
  <h1 class="text-3xl font-bold text-gray-800">Check Out This Recipe</h1>
  <p class="text-sm text-gray-500 mt-1">
    <% if @meal.user_input.present? %>
      Inspired by: <em><%= @meal.user_input %></em>
    <% else %>
      A surprise recipe to try tonight
    <% end %>
  </p>
</div>

<% unless user_signed_in? %>
  <div class="mb-6 bg-orange-50 border border-orange-200 rounded-2xl px-6 py-4 flex items-center justify-between">
    <p class="text-sm text-orange-800">
      <span class="font-semibold">Love this recipe?</span> Sign up to save your favorites and get personalized suggestions.
    </p>
    <%= link_to "Sign Up Free", new_user_registration_path, class: "bg-orange-500 text-white px-5 py-2 rounded-full text-sm font-semibold hover:bg-orange-600 transition whitespace-nowrap ml-4" %>
  </div>
<% end %>

<div class="space-y-6">
  <% @suggestions.each_with_index do |meal, i| %>
    <% actual_index = @suggestion_offset + i %>
    <%= render "meals/recipe_card", meal: meal, index: actual_index, meal_id: @meal.id, favorited: @favorited_indices.include?(actual_index), signed_in: user_signed_in? %>
  <% end %>
</div>

<% unless user_signed_in? %>
  <div class="mt-8 text-center bg-white rounded-2xl p-8 shadow-sm border border-orange-100">
    <h3 class="text-xl font-bold text-gray-800 mb-2">Get Your Own Dinner Ideas</h3>
    <p class="text-gray-600 text-sm mb-4">Tell us what's in your pantry and we'll suggest meals your whole family will love.</p>
    <%= link_to "Get Started", new_user_registration_path, class: "bg-orange-500 text-white px-6 py-3 rounded-full font-semibold hover:bg-orange-600 transition inline-block" %>
  </div>
<% end %>
